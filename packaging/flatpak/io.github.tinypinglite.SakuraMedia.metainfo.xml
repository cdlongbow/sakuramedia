<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.tinypinglite.SakuraMedia</id>

  <name>SakuraMedia</name>
  <name xml:lang="zh_CN">樱视</name>
  <summary>NAS-oriented media discovery and playback platform</summary>
  <summary xml:lang="zh_CN">面向 NAS 用户的观影平台</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      SakuraMedia is a Flutter-based media platform for NAS users, covering
      discovery, subscription, download, playback and metadata translation.
    </p>
    <p xml:lang="zh_CN">
      SakuraMedia 是基于 Flutter 的 NAS 观影平台前端,覆盖影片发现、订阅、
      下载、播放与信息翻译。
    </p>
  </description>

  <launchable type="desktop-id">io.github.tinypinglite.SakuraMedia.desktop</launchable>

  <url type="homepage">https://tinypinglite.github.io/sakuramedia/</url>
  <url type="bugtracker">https://github.com/tinypinglite/sakuramedia/issues</url>
  <url type="vcs-browser">https://github.com/tinypinglite/sakuramedia</url>

  <developer id="io.github.tinypinglite">
    <name>tinypinglite</name>
  </developer>

  <content_rating type="oars-1.1">
    <content_attribute id="sex-nudity">intense</content_attribute>
    <content_attribute id="sex-themes">intense</content_attribute>
  </content_rating>

  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Player</category>
  </categories>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <releases>
    <release version="0.3.6" date="2026-07-19"/>
  </releases>
</component>
